    <!-- Testimonies Section -->
    <section class="section" style="background: var(--bg-light);">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-label">Testimonies</span>
                <h2 class="section-title">What God Is Doing</h2>
                <p>Read the wonderful testimonies of God's power in our assembly.</p>
            </div>

            <div class="services-grid">
                <div class="testimony-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="testimony-icon">
                        <i class="fas fa-quote-left"></i>
                    </div>
                    <h3>Divine Healing</h3>
                    <p>"I came to MFM Addis with a severe illness that doctors couldn't explain. After the Manna Water
                        service, I felt a heavy weight leave me. I went for a checkup and I was completely healed!"</p>
                    <p class="testimony-author">- Sis. Sarah A.</p>
                </div>

                <div class="testimony-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="testimony-icon">
                        <i class="fas fa-quote-left"></i>
                    </div>
                    <h3>Visa Breakthrough</h3>
                    <p>"For 3 years I was struggling with my visa application. During the Night of Solution, the Pastor
                        prayed for open doors. Two weeks later, my visa was approved with a 5-year validity!"</p>
                    <p class="testimony-author">- Bro. David K.</p>
                </div>

                <div class="testimony-card" data-aos="fade-up" data-aos-delay="300">
                    <div class="testimony-icon">
                        <i class="fas fa-quote-left"></i>
                    </div>
                    <h3>Marital Settlement</h3>
                    <p>"I trusted God for a partner for years. After joining the Happy Home prayers, God connected me
                        with my spouse divinely. We are now happily married. Glory to Jesus!"</p>
                    <p class="testimony-author">- Sis. Martha</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ========== GIVING ========== -->
    <section id="giving" class="section">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-label">Giving</span>
                <h2 class="section-title">Support Kingdom Work</h2>
                <p>Your generosity helps us take the gospel to the nations. Partner with us today.</p>
            </div>

            <div class="about-grid">
                <div class="about-card" style="position: relative; height: auto;" data-aos="fade-right">
                    <h3>Bank Transfer</h3>
                    <p>Direct bank deposits can be made to:</p>
                    <div style="margin-top: 20px; text-align: left;">
                        <p><strong>Bank Name:</strong> Commercial Bank of Ethiopia</p>
                        <p><strong>Account Name:</strong> MFM Addis Ababa</p>
                        <p><strong>Account Number:</strong> 1000123456789</p>
                    </div>
                </div>
            </div>
        </div>
